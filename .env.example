# --- Harness-Agent configuration ---

# Which provider adapter to use: "anthropic" (default) or "openai".
# HARNESS_PROVIDER=anthropic

# ============================================================
# Option A — Anthropic (official, or an Anthropic-compatible 中转/代理)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
# Point at a proxy / 中转站 that speaks the Anthropic Messages API.
# Leave unset to use the official endpoint (https://api.anthropic.com).
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy.example.com

# Optional: override the model (default claude-sonnet-4-5-20250929)
# HARNESS_MODEL=claude-sonnet-4-5-20250929

# ============================================================
# Option B — any OpenAI-compatible endpoint
#   (OpenRouter, DeepSeek, Kimi/Moonshot, Qwen, Zhipu, SiliconFlow,
#    local Ollama / vLLM, …). Set HARNESS_PROVIDER=openai to use these.
# ============================================================
# HARNESS_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1     # provider's base URL
# HARNESS_MODEL=deepseek-chat                       # REQUIRED for openai
#
# Examples:
#   DeepSeek:   OPENAI_BASE_URL=https://api.deepseek.com/v1   HARNESS_MODEL=deepseek-chat
#   Kimi:       OPENAI_BASE_URL=https://api.moonshot.cn/v1    HARNESS_MODEL=moonshot-v1-8k
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1  HARNESS_MODEL=anthropic/claude-3.5-sonnet
#   Ollama:     OPENAI_BASE_URL=http://localhost:11434/v1     HARNESS_MODEL=llama3.1   OPENAI_API_KEY=ollama
