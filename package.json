{
  "name": "light-agent-cli",
  "version": "0.4.3",
  "private": false,
  "type": "module",
  "description": "Light-Agent, a local-first coding agent CLI for terminal workflows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bakebakebakebake/light-agent.git"
  },
  "homepage": "https://github.com/bakebakebakebake/light-agent",
  "bugs": {
    "url": "https://github.com/bakebakebakebake/light-agent/issues"
  },
  "keywords": [
    "agent",
    "cli",
    "coding-agent",
    "llm",
    "mcp"
  ],
  "bin": {
    "light-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    "AGENT.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "7.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/diff": "6.0.0",
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
