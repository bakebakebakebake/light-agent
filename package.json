{
  "name": "harness-agent",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "A minimal coding agent CLI built from the docs/ architecture reference",
  "bin": {
    "harness-agent": "./dist/cli.js"
  },
